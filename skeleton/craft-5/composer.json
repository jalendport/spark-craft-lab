{
	"name": "jalendport/spark-craft-lab-instance",
	"description": "Disposable Craft CMS instance minted by spark-craft-lab",
	"type": "project",
	"license": "0BSD",
	"require": {
		"craftcms/cms": "^5.0",
		"vlucas/phpdotenv": "^5.6",
		"yiisoft/yii2-redis": "^2.0"
	},
	"minimum-stability": "dev",
	"prefer-stable": true,
	"config": {
		"allow-plugins": {
			"craftcms/plugin-installer": true,
			"yiisoft/yii2-composer": true
		},
		"optimize-autoloader": true,
		"sort-packages": true,
		"platform": {
			"php": "8.2"
		}
	}
}
